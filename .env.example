# ==== 共通（デプロイ全体で1つ）====
# cron(/drain)用のマスターシークレット。推測されにくい長い文字列に。
ENGINE_SECRET=change-me-to-a-long-random-string
# ワークスペースごとのデータ保存先（Renderは永続ディスク推奨）
DATA_DIR=/var/data
# 投稿文面の生成に使う共通キー（Claude API・全ワークスペース共通）
ANTHROPIC_API_KEY=
# Graph APIバージョン（任意）
GRAPH_VERSION=v21.0

# ※各SNS（X / Facebook / Instagram）のAPIキー・トークンは環境変数ではなく、
#   各メンバーがダッシュボードの「設定 → SNS認証情報」で入力します。
#   サーバーの DATA_DIR/ws/<member>/creds.json にワークスペース別に保存され、
#   ブラウザには保持されません。
